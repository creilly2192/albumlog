---

import "../styles/global.css";

import Header from "../components/Header.astro";

---

<!doctype html>
<html lang="en">
  <head>
    <title>Greatest Albums Project</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap"
        rel="stylesheet"
    />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet">
  </head>
  <body> 
    <Header />
    <main>
        <div class="container">
            <slot />
        </div>
        <div class="music-svg-element">
             <svg width="60" height="80" viewBox="0 0 60 80" fill="none" opacity="0.25">
                <circle cx="15" cy="65" r="10" fill="var(--color-purple)" />
                <rect x="22" y="20" width="3" height="45" fill="var(--color-purple)" />
                <path d="M 25 20 Q 35 18, 40 25" stroke="var(--color-purple)" stroke-width="3" fill="none" />
            </svg>
        </div>
    </main>
  </body>
</html>
