---
import { readAlbums, readNowId } from "../../lib/data";

import BaseLayout from "../../layouts/BaseLayout.astro";

const albums = readAlbums();
const nowId = readNowId();

const album = nowId ? albums.find((a) => a.id === nowId) : null;
const missing = nowId && !album;

---
<BaseLayout title="Now Listening">
<span class="now-listening__label overline">Now Listening</span>

{album ? (
  <>
    <h1 class="now-listening__album">{album.title}</h1>
    <h2 class="now-listening__artist">{album.artist}</h2>
    <p class="now-listening__released">Released {album.year}{album.label ? `, ${album.label}` : ""}</p>
    
{album.ranks ? (
    <div class="now-listening__ranks">
      <h3 class="overline">Rankings</h3>
      {album.ranks?.rollingstone ? <span class="now-listening__rank">Rolling Stone: <strong> #{album.ranks.rollingstone}</strong>/500</span> : null}
      {album.ranks?.apple ? <span class="now-listening__rank">Apple: <strong> #{album.ranks.apple}</strong>/100</span> : null}
    </div>
) : null}

{album.spotifyLink ? (
    <a href={album.spotifyLink} target="_blank" rel="noopener" class="now-listening__spotify-link">Listen on Spotify</a>
) : null}

  </>
) :  missing ? (
  <>
    <p>Pinned album id <code>{nowId}</code> wasn’t found in <code>data/albums.json</code>.</p>
    <p>Run <code>npm run albums:build</code> (then commit) or repick.</p>
  </>
) : (
  <>
    <p>No pinned album yet (or it’s invalid).</p>
    <p>Run <code>npm run pick:album</code> locally to generate <code>data/now.json</code>.</p>
  </>
)}
</BaseLayout>